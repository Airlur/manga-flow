{
  "name": "manga-flow",
  "version": "1.0.0",
  "description": "漫画网页自动翻译插件 - 支持韩漫/日漫/英漫翻译",
  "type": "module",
  "scripts": {
    "dev": "pnpm build:content && vite build --watch",
    "build": "pnpm build:content && pnpm build:other",
    "build:content": "cross-env BUILD_TARGET=content vite build",
    "build:other": "vite build",
    "lint": "eslint src --ext .ts,.js",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "chrome-extension",
    "manga",
    "translation",
    "ocr"
  ],
  "author": "MangaFlow",
  "license": "MIT",
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@types/chrome": "^0.0.268",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "sharp": "^0.34.5",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "localforage": "^1.10.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "simple-icons": "^16.13.0",
    "tesseract.js": "^5.1.0"
  },
  "packageManager": "pnpm@10.28.2"
}